COMPOSE_PROJECT_NAME=hostlink-site-prod
APP_PORT=3300
APP_HEALTHCHECK_PATH=/
NODE_ENV=production
NEXT_PUBLIC_SERVER_URL=https://hostlink.jp

POSTGRES_DB=hostlink_site
POSTGRES_USER=hostlink
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://hostlink:change-me@postgres:5432/hostlink_site

PAYLOAD_SECRET=change-me-payload-secret
CRON_SECRET=change-me-cron-secret
PREVIEW_SECRET=change-me-preview-secret

SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_USER=sales@hostlink.jp
SMTP_PASS=change-me-smtp-password
SMTP_FROM_ADDRESS=sales@hostlink.jp
SMTP_FROM_NAME=HostLink

TURNSTILE_SITE_KEY=change-me-turnstile-site-key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=change-me-turnstile-site-key
TURNSTILE_SECRET_KEY=change-me-turnstile-secret-key
SPAM_IP_HASH_SALT=change-me-spam-salt
SPAM_MIN_SUBMIT_MS=2500
SPAM_RATE_MINUTE_LIMIT=5
SPAM_RATE_HOUR_LIMIT=20
SPAM_BLOCK_MINUTES=30
